PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/student-startup
JWT_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=
OWNER_EMAIL=
COOKIE_DOMAIN=.joincollab.org
CORS_ORIGINS=https://www.joincollab.org,https://joincollab.org
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_PROVIDER=
RESEND_API_KEY=
SENDGRID_API_KEY=
FRONTEND_URL=https://www.joincollab.org
SECURITY_ALERT_EMAIL=
SECURITY_ALERT_WEBHOOK=
SECURITY_ALERT_EVENTS=rate_limit,auth_failure,otp_lockout,admin_2fa_failed,weak_admin_password
